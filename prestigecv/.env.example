# ─── Firebase ───────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# URL to your deployed Firebase Functions
VITE_FIREBASE_FUNCTIONS_URL=https://us-central1-your_project_id.cloudfunctions.net

# ─── Stripe ─────────────────────────────────────────────────
# Get these from: dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get these from: dashboard.stripe.com → Products → Pricing
VITE_STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_LIFETIME_PRICE_ID=price_...

# ─── Firebase Functions env (set via: firebase functions:config:set) ─────────
# These go in your Firebase Functions environment, NOT in .env
# firebase functions:config:set stripe.secret="sk_live_..." stripe.webhook_secret="whsec_..." client.url="https://yourdomain.com"
